# Web app environment variables (Vite / React Router).
# Copy to `.env` and adjust: `cp .env.example .env`
# Only variables prefixed with VITE_ are exposed to the client bundle
# via import.meta.env.

# Base URL of the Commute API, without a trailing slash.
# Used to build request URLs (see app/routes and hooks: import.meta.env.VITE_API_BASE_URL).
# For local dev, point at the API worker (apps/api runs on port 3000).
VITE_API_BASE_URL=http://localhost:3000
