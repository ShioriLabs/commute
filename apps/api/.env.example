# API (Cloudflare Worker) environment variables.
#
# For local development, `wrangler dev` reads secrets/vars from a file named
# `.dev.vars` (not `.env`). Copy this file there and fill in the values:
#     cp .env.example .dev.vars
# In production, set secrets with: `wrangler secret put KCI_API_TOKEN`
#
# Note: the DB (D1) and KV bindings, and the non-secret API_VERSION var, are
# configured in wrangler.toml — they are not set here.

# Token for the KCI (KAI Commuter) upstream API. Required by the station and
# timetable sync routes (see src/routes/sync.ts -> c.env.KCI_API_TOKEN).
KCI_API_TOKEN=

# Optional: override the cache-key version that wrangler.toml [vars] already sets.
# Leave unset to use the wrangler.toml value.
# API_VERSION=20250612
